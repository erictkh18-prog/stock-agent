# Environment Variables Template
# Copy to .env and fill in your values

# API Keys (optional - only needed for premium features)
ALPHA_VANTAGE_KEY=your_api_key_here
NEWSAPI_KEY=your_api_key_here

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Analysis Parameters (days for lookback periods)
FUNDAMENTAL_LOOKBACK_DAYS=730
TECHNICAL_LOOKBACK_DAYS=365
SENTIMENT_LOOKBACK_DAYS=30

# Screening Parameters
MIN_MARKET_CAP=1000000000
MIN_VOLUME=1000000

# Cache Settings (in seconds)
CACHE_TTL_SECONDS=3600

# KB Builder Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_EMAIL=erictkh18@gmail.com
ADMIN_PASSWORD=change-me-to-your-admin-login-password
JWT_EXPIRE_MINUTES=480

# Optional: persistent auth storage (provider-agnostic Postgres)
# Set AUTH_DATABASE_URL to a Postgres connection string.
# If omitted, auth falls back to data/kb_users.json (not persistent on Render free tier).
AUTH_DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: persistent paper-trading storage
# Prefer PAPER_TRADING_DATABASE_URL or DATABASE_URL in production.
# If neither is set, paper trading uses local JSON files (not persistent across deploys).
PAPER_TRADING_DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Safety switch (keep false in production):
# If true, paper trading may fallback to local JSON when Postgres has errors.
PAPER_TRADING_ALLOW_JSON_FALLBACK=false

# Optional: enforce readiness check for both auth + paper-trading Postgres in /health
# In production this is automatically enforced unless explicitly disabled.
HEALTHCHECK_ENFORCE_TRADING_PERSISTENCE=true

# Migration helper script inputs (for Supabase -> Neon or any Postgres -> Postgres move)
SOURCE_DATABASE_URL=postgresql://user:password@source-host:5432/source_db
TARGET_DATABASE_URL=postgresql://user:password@target-host:5432/target_db
