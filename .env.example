# Environment Variables Template
# Copy to .env and fill in your values

# API Keys (optional - only needed for premium features)
ALPHA_VANTAGE_KEY=your_api_key_here
NEWSAPI_KEY=your_api_key_here

# Application Settings
DEBUG=false
LOG_LEVEL=INFO

# Analysis Parameters (days for lookback periods)
FUNDAMENTAL_LOOKBACK_DAYS=730
TECHNICAL_LOOKBACK_DAYS=365
SENTIMENT_LOOKBACK_DAYS=30

# Screening Parameters
MIN_MARKET_CAP=1000000000
MIN_VOLUME=1000000

# Cache Settings (in seconds)
CACHE_TTL_SECONDS=3600

# KB Builder Authentication
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_EMAIL=erictkh18@gmail.com
ADMIN_PASSWORD=change-me-to-your-admin-login-password
JWT_EXPIRE_MINUTES=480

# Optional: persistent auth storage for Render/Supabase
# Set AUTH_DATABASE_URL to a Postgres connection string.
# If omitted, auth falls back to data/kb_users.json (not persistent on Render free tier).
AUTH_DATABASE_URL=postgresql://user:password@host:5432/database
